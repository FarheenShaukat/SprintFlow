DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Empty DATABASE_URL means Django uses local SQLite.
# Supabase PostgreSQL example:
# DATABASE_URL=postgres://postgres.your-ref:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_URL=

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

NEXT_PUBLIC_API_URL=http://localhost:8000/api
FRONTEND_URL=http://localhost:3000

# SMTP can be used in development too. Gmail example shown below.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=SprintFlow AI <your-email@gmail.com>
